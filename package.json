    "dompurify": "^3.4.0",
    "fast-uri": "^3.1.2",
    "fast-xml-builder": "^1.1.7",
    "fast-xml-parser": "^5.7.0",
    "flatted": "^3.4.2",
    "mermaid": "^11.15.0",
